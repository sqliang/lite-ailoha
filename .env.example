# =============================================================================
# Vision Model — Coordinator Agent 使用，需要多模态（看图理解聊天截图）
# 国内可选: qwen-vl-max, glm-4v, step-1v 等
# =============================================================================
VISION_MODEL=gpt-4o
VISION_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VISION_BASE_URL=https://api.openai.com/v1

# =============================================================================
# LLM Model — 子 Agent 使用，纯文本推理即可
# 国内可选: deepseek-chat, moonshot-v1, qwen-turbo 等
# =============================================================================
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Database（SQLite 零配置）
# =============================================================================
DATABASE_URL=sqlite+aiosqlite:///./lite_ailoha.db

# =============================================================================
# LangSmith（可选，调试 Agent 链路）
# =============================================================================
LANGCHAIN_TRACING_V2=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=ls_xxxxxxxx
LANGSMITH_PROJECT=lite-ailoha
